GEMINI_API_KEY=
TAVILY_API_KEY=

# Any secret string - required in every request's X-API-Key header once set
API_KEY=

# Comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Redis - use the internal connection details from your Render Redis
# instance (or Upstash/Redis Cloud if you go external)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

UPLOAD_DIR=backend/uploads/pdfs
TESSERACT_CMD=
MAX_REQUESTS_PER_MINUTE=20
